[node name="TextLabel" type="Label" parent="ScrollContainer/VBoxContainer/VBoxContainer3" unique_id=77691287]
custom_minimum_size = Vector2(10, 10)
layout_mode = 2
theme_override_colors/font_color = Color(0.36078432, 0.75686276, 0.8980392, 1)
theme_override_constants/line_spacing = 8
theme_override_fonts/font = ExtResource("4_y1u6i")
theme_override_font_sizes/font_size = 36
text = "《最南幻想》（暂定名）是一款为大学生量身定制的心理减压互动作品。在这里，没有激烈的战斗，也没有复杂的规则——你只需跟随故事的指引，在一个个熟悉又温柔的校园场景中，停下脚步，与自己对话。

我们相信，压力不应被忽视，也无需独自硬扛。游戏中的每一次选择、每一段对话，都是一次情绪的梳理与释放。你可以在这里暂时卸下焦虑，像躺在北大楼前的草坪上晒太阳一样，让思绪慢慢舒展开来。

本作由南京大学学生团队制作，献给每一位在学业与生活中努力前行的你。愿这片小小的幻想乡，能成为你片刻的安宁。"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

