vertical_alignment = 1

[node name="TextLabel" type="Label" parent="ScrollContainer/VBoxContainer/VBoxContainer4" unique_id=1051715734]
custom_minimum_size = Vector2(10, 10)
layout_mode = 2
theme_override_colors/font_color = Color(0.36078432, 0.75686276, 0.8980392, 1)
theme_override_constants/line_spacing = 8
theme_override_fonts/font = ExtResource("4_y1u6i")
theme_override_font_sizes/font_size = 36
text = "大家好！我们是咕算队（GuTeam）——四名来自南京大学的大一学生。

做这个游戏的念头，源于我们身边太多朋友（包括我们自己）被焦虑、失眠、自我怀疑困扰。我们不是心理专家，但我们想用最擅长的方式——做游戏——来传递一点温暖。

开发过程中，我们反复问自己：“如果我是玩家，此刻最想听到什么？”答案是：“没关系，你已经很好了。”

所以，我们把这句话藏进了游戏的某个角落。希望你在不经意间读到它时，能感到一丝被理解的宽慰。

感谢南京大学心理中心提供的指导，感谢每一位参与测试的同学。如果你在游戏中获得了一点点平静，那就是我们最大的荣幸。

最后，记得：累了就歇一歇，你的努力本身就值得被看见。

—— 咕算队 全体成员
2026年初夏 · 鼓楼"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
